  "pdfContent": {
    "introductionText": "The National Digital Addressing System is a comprehensive platform designed to modernize address management and emergency response services in Equatorial Guinea. This system integrates traditional addressing capabilities with advanced police operations management, creating a unified platform for government services.",
    "introductionText2": "This manual provides complete guidance for all system users, from citizens submitting address requests to administrators managing system-wide operations. The platform serves multiple user roles and facilitates complex workflows while maintaining high security standards.",
    "systemOverviewText": "The platform consists of two primary modules: Address Registry Module: Manages the complete lifecycle of address creation, verification, and publication. Police Operations Module: Handles emergency incident management, unit coordination, and communication systems.",
    "systemOverviewText2": "These modules work together to provide integrated services, enabling emergency responders to access verified address information during incidents and allowing address data to be used across government services.",
    "citizenRole": "Submit new address requests with location details and documentation, track submission status and receive notifications, access their own address records and verification status, resubmit requests after addressing rejection feedback.",
    "fieldAgentRole": "Visit requested locations to capture GPS coordinates, take verification photos and document site conditions, create detailed address drafts with technical specifications, work offline in areas with limited connectivity.",
    "verifierRole": "Review address drafts for accuracy and completeness, check for duplicate addresses in the system, resolve conflicts between multiple submissions, flag problematic requests for additional review, provide recommendations for address improvements.",
    "registrarRole": "Perform final reviews of verified address drafts, publish approved addresses to the official registry, generate Unique Address Codes (UACs) for verified locations, manage address publication status and visibility, handle administrative appeals and complex cases.",
    "policeOperatorRole": "Respond to emergency incidents and update status in real-time, request backup support when situations require additional resources, communicate with dispatchers and other units through secure channels, document incident details and evidence during field operations.",
    "policeDispatcherRole": "Receive emergency calls and create incident records, assign appropriate units based on location and incident type, coordinate multi-unit responses and resource allocation, monitor active incidents and maintain communication links, process backup requests and coordinate additional resources.",
    "policeSupervisorRole": "Monitor unit performance and incident response times, approve backup requests and resource allocation decisions, oversee operations within assigned geographic areas, manage escalations and complex incident situations, conduct performance reviews and process improvements.",
    "policeAdminRole": "Configure system settings and user permissions, manage unit assignments and organizational structure, analyze performance metrics across the entire force, oversee system security and access controls, generate reports for command staff and government officials.",
    "generatedBy": "Generated by National Digital Addressing Authority System",
    "generatedOn": "Generated on:"
  },
